{
  "name": "calidad-orangehrm",
  "version": "1.0.0",
  "description": "Final Software Quality project for OrangeHRM test automation using Cypress",
  "main": "index.js",
  "scripts": {
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "cy:run:chrome": "cypress run --browser chrome",
    "cy:run:frontend": "cypress run --spec \"cypress/e2e/front-end/*.cy.js\"",
    "cy:run:smoke": "cypress run --spec \"cypress/e2e/smoke/*.cy.js\"",
    "report:merge": "npx mochawesome-merge \"cypress/reports/mochawesome*.json\" > cypress/reports/final-report.json",
    "report:generate": "npx marge cypress/reports/final-report.json -f final-report -o cypress/reports",
    "report:open:mac": "open cypress/reports/final-report.html",
    "report:open:win": "start cypress\\reports\\final-report.html",
    "test": "npm run cy:run"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ebriceno13/calidad-orangehrm.git"
  },
  "keywords": [
    "cypress",
    "automation",
    "qa",
    "orangehrm",
    "software-quality"
  ],
  "author": "Enrique Briceno",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/ebriceno13/calidad-orangehrm/issues"
  },
  "homepage": "https://github.com/ebriceno13/calidad-orangehrm#readme",
  "devDependencies": {
    "cypress": "^15.13.1",
    "mochawesome": "^7.1.3",
    "mochawesome-merge": "^5.0.0",
    "mochawesome-report-generator": "^6.2.0"
  }
}